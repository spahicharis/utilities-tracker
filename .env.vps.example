# Host loopback ports used by Docker services (Nginx proxies to these)
BACKEND_BIND_PORT=5000
FRONTEND_BIND_PORT=8080

# Backend runtime
POSTGRES_DB_URL=
SUPABASE_URL=

# Frontend build-time variables
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Keep empty to use same-origin /api behind host Nginx
VITE_API_BASE_URL=
